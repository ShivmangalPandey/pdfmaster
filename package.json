{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx backend/server.ts",
    "build:frontend": "vite build frontend",
    "build:backend": "esbuild backend/server.ts --bundle --platform=node --format=esm --packages=external --outfile=server.js",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "NODE_ENV=production node server.js",
    "clean": "rm -rf frontend/dist server.js backend/uploads backend/output",
    "lint": "tsc --noEmit --project frontend/tsconfig.json"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.19",
